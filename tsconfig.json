{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Paths mapping for local packages development */
    "paths": {
      "@streamhub/shared-types": ["./packages/shared-types/src/index.ts"],
      "@streamhub/shared-utils": ["./packages/shared-utils/src/index.ts"],
      "@streamhub/shared-hooks": ["./packages/shared-hooks/src/index.ts"],
      "@streamhub/shared-store": ["./packages/shared-store/src/index.ts"],
      "@streamhub/shared-ui": ["./packages/shared-ui/src/index.tsx"],
      "@streamhub/firebase": ["./packages/firebase/src/index.ts"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"]
}
