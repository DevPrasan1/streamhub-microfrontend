{
  "name": "micro-frontend-vite-boilerplate",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:host": "npm run dev -w @mfe/host",
    "dev:browser": "npm run dev -w @mfe/video-browser",
    "dev:player": "npm run dev -w @mfe/player",
    "dev:community": "npm run dev -w @mfe/community",
    "dev": "concurrently \"npm:dev:*\"",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspaces --if-present",
    "start": "npm run build && concurrently \"npm run dev:host\" \"npm run preview -w @mfe/video-browser\" \"npm run preview -w @mfe/player\" \"npm run preview -w @mfe/community\"",
    "watch:browser": "npm run build -w @mfe/video-browser -- --watch",
    "watch:player": "npm run build -w @mfe/player -- --watch",
    "watch:community": "npm run build -w @mfe/community -- --watch",
    "watch": "concurrently \"npm:watch:*\"",
    "dev:mfe": "npm run build && concurrently \"npm run dev:host\" \"npm run preview -w @mfe/video-browser\" \"npm run preview -w @mfe/player\" \"npm run preview -w @mfe/community\" \"npm run watch:browser\" \"npm run watch:player\" \"npm run watch:community\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  }
}
