{
  "name": "micro-frontend-vite-boilerplate",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:host": "npm run dev -w @mfe/host",
    "dev:catalog": "npm run dev -w @mfe/product-catalog",
    "dev:details": "npm run dev -w @mfe/product-details",
    "dev:reviews": "npm run dev -w @mfe/product-reviews",
    "dev": "concurrently \"npm:dev:*\"",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspaces --if-present",
    "start": "npm run build && concurrently \"npm run dev:host\" \"npm run preview -w @mfe/product-catalog\" \"npm run preview -w @mfe/product-details\" \"npm run preview -w @mfe/product-reviews\"",
    "watch:catalog": "npm run build -w @mfe/product-catalog -- --watch",
    "watch:details": "npm run build -w @mfe/product-details -- --watch",
    "watch:reviews": "npm run build -w @mfe/product-reviews -- --watch",
    "watch": "concurrently \"npm:watch:*\"",
    "dev:mfe": "npm run build && concurrently \"npm run dev:host\" \"npm run preview -w @mfe/product-catalog\" \"npm run preview -w @mfe/product-details\" \"npm run preview -w @mfe/product-reviews\" \"npm run watch:catalog\" \"npm run watch:details\" \"npm run watch:reviews\"",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.11.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "storybook": "^10.5.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vite": "^5.4.8"
  }
}
